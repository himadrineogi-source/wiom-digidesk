{
  "name": "digidesk-backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.cjs",
  "scripts": {
    "build": "npm run build:css && next build",
    "build:css": "tailwindcss -i ./src/styles/digidesk.css -o ./public/digidesk.css --minify",
    "check": "node -c server.cjs && node -c scripts/seed_supabase_state.cjs && npm run build",
    "dev": "npm run build:css && next dev",
    "start": "next start",
    "start:express": "node server.cjs",
    "supabase:seed": "node scripts/seed_supabase_state.cjs --replace",
    "test": "npm run check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.11.0 <26"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
